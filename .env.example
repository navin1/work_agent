# Model — switch here without touching code
AGENT_MODEL=gemini-2.5-flash

# Google Cloud (auth via ADC: gcloud auth application-default login)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE
# Optional: path to a GCP service-account JSON file for AI model credentials.
# If omitted, Application Default Credentials (gcloud auth / metadata server) are used.
AGENT_SA_KEY_PATH=
# SSL verification for outbound HTTP (Airflow, GitHub, GCS).
# Set to false for corporate proxies (ZScaler etc), or a path to your CA bundle.
HTTP_SSL_VERIFY=true

# BigQuery
# BQ_BILLING_PROJECT: project charged for slot usage (who pays for queries).
#   This is often a central shared project, separate from where the data lives.
#   Falls back to the first entry in BQ_ALLOWED_PROJECTS if not set.
BQ_BILLING_PROJECT=billing-project-id

# Comma-separated project IDs whose data the agent is allowed to read.
BQ_ALLOWED_PROJECTS=project-a,project-b,project-c

# Cloud Composer
# Option A — direct Airflow URL (versions not auto-discovered):
#   COMPOSER_ENVS=prod:https://your-airflow-url,staging:https://your-staging-url
# Option B — GCP path (auto-discovers Airflow URL, versions, and BQ SDK from Composer API):
#   COMPOSER_ENVS=prod:gcp-project/location/composer-env-name,staging:gcp-project/location/composer-env-name
#   Requires: pip install google-cloud-orchestration-airflow + composer.environments.get permission
COMPOSER_ENVS=prod:https://your-prod-airflow-url,staging:https://your-staging-airflow-url

# Fallback SDK versions used by optimisation tools when no composer_env is passed.
# These should match the Airflow / BQ SDK versions in your Composer environments.
DEFAULT_AIRFLOW_VERSION=2.6.3
DEFAULT_BQ_SDK=google-cloud-bigquery==3.11.0
DEFAULT_PYTHON_VERSION=3.10

# Git
GIT_MODE=api
GIT_API_BASE_URL=https://api.github.com
GIT_REPO=org/repo
GIT_BRANCH=main
GIT_API_TOKEN=ghp_xxx
GIT_FILE_EXTENSIONS=.sql,.py,.yaml
GIT_ROOT_PATHS=dags/,sql/,config/

# GCS
GCS_BUCKETS=dags-bucket,sql-bucket
GCS_PREFIXES=dags/,sql/
GCS_FILE_EXTENSIONS=.sql,.py,.yaml
# Root folder(s) in GCS/Git where DAG .py files live (supports subfolders).
# Comma-separated. Falls back to GCS_PREFIXES if not set.
DAG_FOLDER=dags/

# Control-M / Confluence integration
# Used by the DAG optimisation doc_md panel to render Control-M job links.
# CONFLUENCE_BASE_URL: base URL for job documentation pages.
#   Link built as: CONFLUENCE_BASE_URL/<CONTROL_M_JOB_NAME>
#   Leave blank to show the job name as plain text (no hyperlink).
# CONTROLM_FOLDER: the Control-M folder that owns the jobs (e.g. FIN_REPORTS).
# CONTROLM_SERVER: the Control-M server name (e.g. PROD_CTM_SERVER).
CONFLUENCE_BASE_URL=https://confluence.yourcompany.com/display/SPACE
CONTROLM_FOLDER=YOUR_FOLDER
CONTROLM_SERVER=YOUR_SERVER

# Schema Audit — MySQL-to-BigQuery column reconciliation
# SCHEMA_METADATA_PROJECT: GCP project that hosts the metadata BQ views.
# SCHEMA_HEADER_VIEW / SCHEMA_DETAIL_VIEW: fully-qualified BQ view refs (project.dataset.view).
# SCHEMA_BQ_PROJECT_PROD: BQ project where prod EDA views live (compared against MySQL prod).
# SCHEMA_BQ_PROJECT_UAT: BQ project where UAT EDA views live (optional, falls back to SCHEMA_METADATA_PROJECT).
# SCHEMA_AUDIT_OUTPUT_DIR: local folder for Excel/JSON output (defaults to ./exports).
SCHEMA_METADATA_PROJECT=metadata-project-id
SCHEMA_HEADER_VIEW=metadata-project-id.schema_meta.header_view
SCHEMA_DETAIL_VIEW=metadata-project-id.schema_meta.detail_view
SCHEMA_BQ_PROJECT_PROD=prod-project-id
SCHEMA_BQ_PROJECT_UAT=uat-project-id
SCHEMA_AUDIT_OUTPUT_DIR=./exports

# Storage / paths
# DATA_ROOT: root folder for Excel mapping/master files (data/mapping/, data/master/).
# USER_DATA_ROOT: persisted user data — glossary, saved queries, validation cache, etc.
# CONFIG_ROOT: folder containing config JSON files (excel_mapping.json, dag_mapping.json).
# EXPORTS_ROOT: folder for generated exports (optimised files, schema audit Excel/JSON).
DATA_ROOT=./data
USER_DATA_ROOT=./user_data
CONFIG_ROOT=./config
EXPORTS_ROOT=./exports
AUDIT_LOG_PATH=audit_log.jsonl
LARGE_FILE_ROW_THRESHOLD=50000
RECONCILIATION_CACHE_TTL_MINUTES=30
